{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; img-src 'self' data: https://i.vimeocdn.com https://static.wixstatic.com; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; frame-src https://player.vimeo.com https://www.youtube.com https://www.youtube-nocookie.com; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests;"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:woff2|woff))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/contact-9",                   "destination": "/contact/",                       "permanent": true },
    { "source": "/filming-1",                   "destination": "/about/",                         "permanent": true },
    { "source": "/fixing",                      "destination": "/fixing/",                        "permanent": true },
    { "source": "/remote-filming",              "destination": "/services/",                      "permanent": true },
    { "source": "/stock-footage",               "destination": "https://stock.highlyvisual.com/", "permanent": true },
    { "source": "/product-page/:slug*",         "destination": "https://hirevisual.com/",         "permanent": true },
    { "source": "/pages-sitemap.xml",           "destination": "/sitemap.xml",                    "permanent": true },
    { "source": "/store-products-sitemap.xml",  "destination": "/sitemap.xml",                    "permanent": true },
    { "source": "/store-categories-sitemap.xml","destination": "/sitemap.xml",                    "permanent": true },
    { "source": "/sitemap-index.xml",           "destination": "/sitemap.xml",                    "permanent": true }
  ]
}

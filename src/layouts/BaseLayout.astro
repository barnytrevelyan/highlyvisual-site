---
import '../styles/tokens.css';
import '../styles/animations.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SiteBand from '../components/SiteBand.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  canonical?: string;
  bodyClass?: string;
  // JSON-LD blocks injected into <head>. Each entry becomes its own
  // <script type="application/ld+json"> tag so search engines and AI crawlers
  // can pick up page-level schema (CreativeWork, BreadcrumbList, VideoObject,
  // ItemList etc.) on top of the sitewide Organization + Person blocks below.
  extraSchema?: Record<string, unknown>[];
  // URL of an image (relative path or absolute) to <link rel="preload"> for LCP.
  preloadImage?: string;
  // Responsive LCP preload: when set, the hero is preloaded via imagesrcset so
  // a phone fetches the ~100KB 800w variant instead of the full-size image.
  preloadImageSrcset?: string;
  preloadImageSizes?: string;
  preloadImageType?: string;
  // Sitewide pre-footer band. Defaults to the full call-to-action treatment.
  // Pages that already render their own bespoke final CTA (homepage, contact)
  // pass `band="compact"` to keep just the credentials strip + sister-site
  // tiles; pages can opt out entirely with `band="none"`.
  band?: 'full' | 'compact' | 'none';
  bandHeading?: string;
  bandLede?: string;
}

const {
  title,
  description,
  ogImage = '/img/og-default.jpg',
  ogType = 'website',
  canonical,
  bodyClass,
  extraSchema = [],
  preloadImage,
  preloadImageSrcset,
  preloadImageSizes,
  preloadImageType,
  band = 'full',
  bandHeading,
  bandLede,
} = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const absoluteOgImage = new URL(ogImage, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Scroll-reveal gate + safety timer. Externalised so it passes
         `script-src 'self'` in the CSP — the inline version was being
         blocked. Loaded synchronously (no defer/async) so the `.has-js`
         class is on <html> before the first reveal element paints. -->
    <script is:inline src="/scripts/animations-gate.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Barny Trevelyan-Johnson" />
    <meta name="theme-color" content="#0A0A0B" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${title}`} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_GB" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content={`${site.name} — ${title}`} />

    <!-- Performance: preconnect to the media provider we embed -->
    <link rel="preconnect" href="https://player.vimeo.com" />
    <link rel="dns-prefetch" href="https://i.vimeocdn.com" />

    <!-- Fonts — self-hosted Inter (woff2 in /fonts), declared via @font-face in
         tokens.css with font-display: swap. No third-party, render-blocking
         request. Preload the two weights used above the fold (body 400,
         display 800) so first paint isn't gated on the font fetch. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-400.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-800.woff2" crossorigin />

    {preloadImage && (
      <link
        rel="preload"
        as="image"
        href={preloadImageSrcset ? undefined : preloadImage}
        imagesrcset={preloadImageSrcset}
        imagesizes={preloadImageSrcset ? (preloadImageSizes ?? '100vw') : undefined}
        type={preloadImageType}
        fetchpriority="high"
      />
    )}

    <!-- WebSite JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': site.url + '/#website',
      url: site.url,
      name: site.name,
      description: site.description,
      inLanguage: 'en-GB',
      publisher: { '@id': site.url + '/#organization' },
    })} />

    <!-- LocalBusiness + Organization JSON-LD (merged via @type array so the
         Organization record on the homepage is also a LocalBusiness for Maps
         and rich-result eligibility) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': ['Organization', 'LocalBusiness', 'ProfessionalService'],
      '@id': site.url + '/#organization',
      name: site.name,
      alternateName: 'Highly Visual Limited',
      url: site.url,
      logo: site.url + '/img/logo.png',
      image: site.url + '/img/portrait-barny-flying.jpg',
      foundingDate: '2002',
      founder: { '@type': 'Person', '@id': site.url + '/#person' },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Nairobi',
        addressRegion: 'Nairobi County',
        addressCountry: 'KE',
      },
      geo: { '@type': 'GeoCoordinates', latitude: -1.286389, longitude: 36.817223 },
      areaServed: [
        { '@type': 'Country', name: 'Kenya' },
        { '@type': 'Country', name: 'Tanzania' },
        { '@type': 'Country', name: 'Uganda' },
        { '@type': 'Country', name: 'Rwanda' },
        { '@type': 'Place', name: 'East Africa' },
      ],
      email: site.email,
      telephone: site.phone,
      priceRange: '$$$$',
      description: site.description,
      knowsAbout: [
        'aerial cinematography',
        'drone cinematography',
        'natural history filmmaking',
        'wildlife cinematography',
        'film fixing Kenya',
        'KFCB-registered local film agent',
        'broadcast production services East Africa',
      ],
      hasCredential: [
        { '@type': 'EducationalOccupationalCredential', credentialCategory: 'license', name: 'UK CAA PfCO UAS 9543 (2017)' },
        { '@type': 'EducationalOccupationalCredential', credentialCategory: 'registration', name: 'KFCB-registered local film agent (Kenya)' },
      ],
      sameAs: [
        site.social.instagram,
        site.social.linkedin,
        site.social.vimeo,
        site.social.youtube,
        site.social.imdb,
        site.social.facebook,
        site.social.talentManager,
      ],
    })} />

    <!-- Person JSON-LD — Barny as the named operator -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      '@id': site.url + '/#person',
      name: 'Barny Trevelyan-Johnson',
      givenName: 'Barny',
      familyName: 'Trevelyan-Johnson',
      jobTitle: 'Drone Operator · Cinematographer',
      worksFor: { '@id': site.url + '/#organization' },
      url: site.url + '/about/',
      image: site.url + '/img/portrait-barny-flying.jpg',
      nationality: { '@type': 'Country', name: 'United Kingdom' },
      workLocation: { '@type': 'City', name: 'Nairobi, Kenya' },
      sameAs: [
        site.social.linkedin,
        site.social.imdb,
        site.social.vimeo,
        site.social.youtube,
        site.social.talentManager,
        site.social.instagram,
      ],
      hasCredential: [
        { '@type': 'EducationalOccupationalCredential', credentialCategory: 'license', name: 'UK CAA Permission for Commercial Operations — UAS 9543 (2017)' },
      ],
      award: [
        'Drone-operator contribution to Outstanding Cinematography for a Non-Fiction Programme, 2021 Primetime Creative Arts Emmy Awards — A Life on Our Planet (Silverback Films / Netflix)',
        'Drone-operator contribution to Best Cinematography (docuseries), 2022 Critics Choice Documentary Awards — Our Great National Parks (Wild Space / Higher Ground / Netflix)',
        'Drone-operator contribution to Outstanding Travel, Adventure and Nature Program, 2023 Daytime Emmy Awards — Wild Babies (Plimsoll / Netflix)',
        'Drone-operator contribution to Animal Behaviour Long Form, 2023 Jackson Wild Media Awards — Our Planet 2 (Silverback Films / Netflix)',
      ],
    })} />

    {extraSchema.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class={bodyClass}>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
      {band !== 'none' && (
        <SiteBand
          compact={band === 'compact'}
          heading={bandHeading}
          lede={bandLede}
        />
      )}
    </main>
    <Footer />
    <script is:inline src="/scripts/animations.js" defer></script>
  </body>
</html>

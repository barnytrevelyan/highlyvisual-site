---
import '../styles/tokens.css';
import '../styles/animations.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  bodyClass?: string;
}

const { title, description, ogImage = '/img/hero-1-drone-bob-poole.jpg', canonical, bodyClass } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      // Engage the scroll-reveal gate only when JS is available. animations.js
      // sets window.__hvAnimationsInit when it runs successfully — if that flag
      // isn't set within 1500ms (404, parse error, blocked by CSP) the safety
      // timer below forces every .reveal element visible so content can never
      // be stuck at opacity:0.
      document.documentElement.classList.add('has-js');
      window.addEventListener('DOMContentLoaded', function () {
        setTimeout(function () {
          if (window.__hvAnimationsInit) return;
          document.documentElement.classList.remove('has-js');
          document.querySelectorAll('.reveal, .reveal-stagger').forEach(function (el) {
            el.classList.add('is-in-view');
          });
        }, 1500);
      });
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0A0B" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/img/logo.png" type="image/png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_GB" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Organization JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: site.name,
      url: site.url,
      logo: site.url + '/img/logo.png',
      foundingDate: '2002',
      founder: { '@type': 'Person', name: 'Barny Trevelyan-Johnson' },
      address: { '@type': 'PostalAddress', addressLocality: 'Nairobi', addressCountry: 'KE' },
      email: site.email,
      telephone: site.phone,
      description: site.description,
      sameAs: [
        site.social.instagram,
        site.social.linkedin,
        site.social.vimeo,
        site.social.youtube,
        site.social.imdb,
        site.social.facebook,
        site.social.talentManager,
      ],
    })} />

    <!-- Person JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Barny Trevelyan-Johnson',
      jobTitle: 'Drone Operator · Cinematographer',
      worksFor: { '@type': 'Organization', name: site.name },
      url: site.url + '/about/',
      image: site.url + '/img/portrait-attenborough-hires.png',
      sameAs: [
        site.social.linkedin,
        site.social.imdb,
        site.social.vimeo,
        site.social.youtube,
        site.social.talentManager,
      ],
      award: [
        'Honored by the Television Academy, Primetime Creative Arts Emmy 2021 — Outstanding Cinematography for a Non-Fiction Programme contribution to A Life on Our Planet',
        'Critics Choice Documentary Award 2022 — Best Cinematography (docuseries) for Our Great National Parks',
        'Daytime Emmy 2023 — Outstanding Travel, Adventure and Nature Program for Wild Babies',
        'Jackson Wild 2023 — Animal Behaviour Long Form for Our Planet 2',
      ],
    })} />
  </head>
  <body class={bodyClass}>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script src="/scripts/animations.js" defer></script>
  </body>
</html>

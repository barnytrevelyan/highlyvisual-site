---
import BaseLayout from '../layouts/BaseLayout.astro';
import AwardsGrid from '../components/AwardsGrid.astro';
import Picture from '../components/Picture.astro';
import { site } from '../data/site';
import { testimonials } from '../data/testimonials';

const featuredTestimonials = [
  testimonials.find((t) => t.id === 'sally-thomson-iaj')!,
  testimonials.find((t) => t.id === 'barny-revill-earth-from-space')!,
];

const title = 'About — Barny Trevelyan-Johnson, drone operator, Nairobi';
const description =
  'Founded by Barny Trevelyan-Johnson — CAA-licensed drone operator, KFCB-registered film agent. 24-year practice, 14+ countries, contributions to Emmy- and Critics Choice-winning productions.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: 'About', item: new URL('/about/', Astro.site).toString() },
  ],
};

const aboutPage = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: new URL('/about/', Astro.site).toString(),
  primaryImageOfPage: new URL('/img/portrait-barny-flying.jpg', Astro.site).toString(),
  about: { '@id': new URL('/', Astro.site).toString() + '#person' },
  mainEntity: { '@id': new URL('/', Astro.site).toString() + '#organization' },
};

// FAQ — single source of truth for BOTH the visible Q&A section below and the
// FAQPage schema, so structured data always reflects content the user can see
// (Google requirement; previously the schema had no visible counterpart).
const faqs = [
  {
    q: 'Where is Highly Visual based?',
    a: 'Nairobi, Kenya. Operations span East Africa with regular work in Tanzania, Uganda, Rwanda, Botswana, South Africa and beyond.',
  },
  {
    q: 'Is Barny Trevelyan-Johnson CAA-licensed for drone operations?',
    a: 'Yes. UK Civil Aviation Authority Permission for Commercial Operations (PfCO) UAS 9543, continuously held since 2017. Highly Visual was the first company in East Africa to operate professionally with drones for broadcast.',
  },
  {
    q: 'Is Highly Visual a KFCB-registered film fixer?',
    a: 'Yes — Highly Visual Limited is a registered local film agent with the Kenya Film Classification Board, capable of full local production support including permits, scouting, crew, vehicles, helicopters and customs.',
  },
  {
    q: 'What production houses has Barny worked with?',
    a: 'BBC Natural History Unit, Silverback Films, Plimsoll Productions, Offspring Films, National Geographic, Disney+, Netflix, Apple TV+, Channel 4, Wild Space Productions, Higher Ground Productions, Nutopia, Wildstar Films, Humble Bee, Asylum Entertainment and others.',
  },
  {
    q: 'Does Highly Visual provide stock footage or equipment hire?',
    a: 'Yes — via two sister businesses. Equipment hire is at hirevisual.com (cinema-grade rental including DJI Inspire 3, Sony FX6/FX3, full lighting and audio kits). Broadcast 4K+ stock footage is at stock.highlyvisual.com (2,700+ clips, discounted for African productions, students and NGOs).',
  },
  {
    q: 'Does Barny operate solo or with a crew?',
    a: 'Solo practice. Barny operates as a single-named cinematographer and drone operator. Crew is engaged per-production from a long-standing East African network.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout
  title={title}
  description={description}
  ogImage="/img/portrait-barny-flying.jpg"
  ogType="profile"
  preloadImage="/img/portrait-barny-flying.webp"
  preloadImageType="image/webp"
  extraSchema={[breadcrumb, aboutPage, faqSchema]}
>

  <!-- About hero — portrait + intro statement -->
  <section class="about-hero">
    <div class="container about-hero-inner">
      <figure class="about-portrait reveal reveal--scale">
        <Picture src="/img/portrait-barny-flying.jpg" alt="Barny Trevelyan-Johnson piloting a drone on location in East Africa — operator portrait by Michel Laplace-Toulouse" loading="eager" fetchpriority="high" />
        <figcaption class="about-portrait__credit">Photo · Michel Laplace-Toulouse</figcaption>
      </figure>
      <div class="about-intro reveal">
        <p class="eyebrow">About</p>
        <h1>An ethical, green, and compliant filmmaking company.</h1>
        <p class="about-lede">
          Highly Visual is deeply committed to responsible filmmaking and conservation.
          With a focus on natural history, every project adheres to strict environmental
          guidelines, minimising impact on wildlife and ecosystems.
        </p>
        <p class="about-lede">
          The company prioritises compliance with local laws — permits, wildlife-protection
          regulations, KFCB and KCAA — while fostering strong relationships with local
          communities and conservation organisations to support ethical storytelling.
        </p>
        <div class="about-hero-cta">
          <a href="/contact/" class="cta cta--primary">Start a conversation</a>
          <a href="/work/" class="cta cta--ghost">See the work</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Company story / timeline -->
  <section class="container reveal" aria-label="Company history">
    <p class="section-title">The story</p>
    <h2>Twenty-four years and counting.</h2>
    <p class="section-lede">
      The company started as a stills practice in Tanzania in 2002. We moved to Kenya in 2013,
      became the first company in the region to work professionally with drones, and have
      since evolved into a film-led practice across natural-history broadcast, fixing and
      commercial production.
    </p>
    <div class="timeline reveal-stagger">
      <div class="timeline-event">
        <p class="timeline-year">2002</p>
        <h3>Founded in Tanzania</h3>
        <p>
          Highly Visual is established. Initial focus: stills photography across East African
          natural-history and conservation subjects.
        </p>
      </div>
      <div class="timeline-event">
        <p class="timeline-year">2013</p>
        <h3>Moved to Kenya</h3>
        <p>
          The company moves to Nairobi. East African production, fixing and aerial work become
          the core practice.
        </p>
      </div>
      <div class="timeline-event">
        <p class="timeline-year">2017</p>
        <h3>CAA-licensed drone operator</h3>
        <p>
          Barny becomes a CAA-approved drone pilot with a Permission for Commercial Operations
          (PfCO UAS 9543) — issued by the UK Civil Aviation Authority. Highly Visual
          becomes the first company in the region to work professionally with drones for broadcast.
        </p>
      </div>
      <div class="timeline-event">
        <p class="timeline-year">2020 — 2024</p>
        <h3>Honored across six award cycles</h3>
        <p>
          Drone-operator and aerial cinematography contributions to productions honoured by
          the Television Academy (Primetime &amp; Daytime Emmys), Critics Choice, Jackson Wild,
          and others. See the detailed list below.
        </p>
      </div>
      <div class="timeline-event">
        <p class="timeline-year">Today</p>
        <h3>14+ countries, full broadcast tier</h3>
        <p>
          Active across the BBC NHU, Silverback Films, Plimsoll, Offspring, Nat Geo / Disney+
          and Netflix slates. KFCB-registered local film agent. Operates with current Kenyan
          and UK licences, fully insured. Sister businesses at <a href={site.sister.hire.url} target="_blank" rel="noopener noreferrer">hirevisual.com</a>
          (cinema-grade rental) and <a href={site.sister.stock.url} target="_blank" rel="noopener noreferrer">stock.highlyvisual.com</a> (4K+ broadcast archive).
        </p>
      </div>
    </div>
  </section>

  <!-- Banner — operator at work, narrative bridge from history to today -->
  <figure class="about-banner reveal">
    <Picture src="/img/heli-cabin-dusk.jpg" alt="Inside a helicopter cabin at dusk, looking out over East African dryland" loading="lazy" />
    <figcaption>Last-light heli transit over the dryland — most of the working day is on aircraft or on foot.</figcaption>
  </figure>

  <!-- Operator bio (Barny, specifically) -->
  <section class="container reveal" aria-label="About Barny">
    <div class="bio-block">
      <div class="bio-block__main">
        <p class="section-title">The operator</p>
        <h2>Barny Trevelyan-Johnson.</h2>
        <p class="bio-block__lede">
          The most experienced drone operator in the region, with over ten years of professional
          drone work and a deeper photography and cinematography practice that began two decades
          earlier. Holds current Kenyan and UK licences and is fully insured.
        </p>
        <p>
          Operates professionally across 14+ countries, including some of the planet's most extreme
          environments — Arctic, Antarctic, high-altitude, marine, dryland.
          Documentary photography consultant and BBC collaborating photographer.
        </p>
        <p>
          Comfortable working as part of a large crew or independently; happy to arrange remote
          or reactionary filming where the production can't be on site.
        </p>
      </div>
      <aside class="bio-block__creds">
        <p class="section-title">Credentials</p>
        <ul class="creds-list">
          <li><strong>UK CAA PfCO</strong> — Permission for Commercial Operations, UAS 9543. Issued 2017.</li>
          <li><strong>KFCB-registered</strong> local film agent in Kenya.</li>
          <li><strong>Current licences</strong> in both Kenya and the United Kingdom.</li>
          <li><strong>Fully insured</strong> for commercial drone operations.</li>
          <li><strong>14+ countries</strong> of professional fieldwork, including extreme environments.</li>
          <li><strong>PADI Diving Licence</strong> · First Aid · Motorcycle Licence · EU Work Permit.</li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- Awards section -->
  <AwardsGrid label="Awards & recognition" />

  <!-- Conservation context banner — wildlife close-up -->
  <figure class="about-banner about-banner--portrait reveal">
    <Picture src="/img/wildlife-cheetah-profile.jpg" alt="Cheetah in profile on long grass — natural-history subject coverage" loading="lazy" />
    <figcaption>The work is for the subjects in front of the lens — every project adheres to strict environmental and proximity guidelines.</figcaption>
  </figure>

  <!-- Brand pillars -->
  <section class="container reveal" aria-label="How I work">
    <p class="section-title">How I work</p>
    <h2>Ethics first.</h2>
    <div class="pillars-grid reveal-stagger">
      {site.pillars.map((p) => (
        <article class="pillar">
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- Kit list -->
  <section class="container reveal" aria-label="Kit">
    <p class="section-title">Kit</p>
    <h2>Cinema-tier across drone, ground and audio.</h2>
    <p class="section-lede">
      Owned kit is supplemented through the in-house rental house
      <a href={site.sister.hire.url} target="_blank" rel="noopener noreferrer">hirevisual.com</a>,
      so production-day rigs scale to the brief.
    </p>
    <div class="kit-grid">
      <div>
        <h3>Drones</h3>
        <ul>{site.kit.drones.map((k) => <li>{k}</li>)}</ul>
      </div>
      <div>
        <h3>Cinema cameras</h3>
        <ul>{site.kit.cinemaCameras.map((k) => <li>{k}</li>)}</ul>
      </div>
      <div>
        <h3>Lenses</h3>
        <ul>{site.kit.lenses.map((k) => <li>{k}</li>)}</ul>
      </div>
      <div>
        <h3>Audio</h3>
        <ul>{site.kit.sound.map((k) => <li>{k}</li>)}</ul>
      </div>
      <div>
        <h3>Other</h3>
        <ul>{site.kit.other.map((k) => <li>{k}</li>)}</ul>
      </div>
    </div>
  </section>

  <!-- Locations banner — where the work happens -->
  <figure class="about-banner reveal">
    <Picture src="/img/aerial-migration-mara.jpg" alt="Aerial of wildebeest migration across the Mara plains" loading="lazy" />
    <figcaption>Wildebeest migration aerial, Maasai Mara — recurring assignment territory.</figcaption>
  </figure>

  <!-- Locations -->
  <section class="container reveal" aria-label="Locations">
    <p class="section-title">Where I work</p>
    <h2>14 countries. East African base.</h2>
    <p class="section-lede">
      Operating from Nairobi as the home base, with extensive ongoing fieldwork across the East
      African parks and conservancies and recurring international assignments.
    </p>
    <div class="locations-grid reveal-stagger">
      <div>
        <h3>Countries</h3>
        <p class="locations-list">{site.countries.join(' · ')}</p>
      </div>
      <div>
        <h3>East African parks &amp; conservancies</h3>
        <p class="locations-list">{site.parks.join(' · ')}</p>
      </div>
    </div>
  </section>

  <!-- Featured testimonials -->
  <section class="container reveal" aria-label="Testimonials">
    <p class="section-title">What clients say</p>
    <div class="about-testimonials">
      {featuredTestimonials.map((t) => (
        <figure class="pull-quote-card">
          <blockquote>{t.quote}</blockquote>
          <figcaption><strong>{t.speaker}</strong> · {t.role} · <em>{t.production}</em></figcaption>
        </figure>
      ))}
    </div>
    <p class="featured-cta"><a href="/work/" class="cta cta--ghost">More projects, more quotes →</a></p>
  </section>

  <!-- FAQ — visible Q&A backing the FAQPage schema -->
  <section class="container reveal" aria-label="Frequently asked questions">
    <p class="section-title">FAQ</p>
    <h2>Questions I get asked.</h2>
    <div class="faq-list reveal-stagger">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary><span>{f.q}</span><span class="faq-mark" aria-hidden="true"></span></summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Final CTA -->
  <section class="container reveal final-cta-section" aria-label="Get in touch">
    <h2>Looking for someone to fly?</h2>
    <div class="final-cta-row">
      <a href="/contact/" class="cta">Start a conversation</a>
      <a href="/services/" class="cta cta--ghost">Services overview</a>
      <a href="/fixing/" class="cta cta--ghost">Fixing services</a>
    </div>
  </section>

</BaseLayout>

<style>
  .about-hero-cta {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-3);
    flex-wrap: wrap;
  }

  .about-hero {
    padding-top: clamp(120px, 18vh, 200px);
    padding-bottom: var(--space-5);
  }
  .about-hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.3fr);
    gap: var(--space-5);
    align-items: center;
  }
  .about-portrait {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--surface);
    margin: 0;
  }
  .about-portrait img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .about-portrait__credit {
    position: absolute;
    right: 12px;
    bottom: 10px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0.7;
    background: rgba(10, 10, 11, 0.55);
    padding: 4px 8px;
    border-radius: 2px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .about-intro h1 {
    font-size: clamp(36px, 4.8vw, 64px);
    max-width: 18ch;
    margin: var(--space-1) 0 var(--space-3);
    line-height: 1.05;
  }
  .about-lede {
    font-size: clamp(15px, 1.4vw, 19px);
    line-height: 1.65;
    color: var(--text);
    opacity: 0.92;
    max-width: 580px;
    margin-bottom: var(--space-2);
  }
  @media (max-width: 900px) {
    .about-hero-inner { grid-template-columns: 1fr; gap: var(--space-3); }
  }

  /* Body banner images */
  .about-banner {
    margin: var(--space-5) 0;
    padding: 0;
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .about-banner { margin: var(--space-3) 0; }
  }
  .about-banner img {
    width: 100%;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    display: block;
  }
  .about-banner--portrait img {
    aspect-ratio: 16 / 9;
  }
  .about-banner figcaption {
    max-width: var(--container-max);
    margin: var(--space-2) auto 0;
    padding: 0 var(--container-pad);
    font-size: 13px;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    line-height: 1.55;
  }

  /* Bio portrait inside bio block */
  .bio-portrait {
    margin: 0 0 var(--space-3);
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--surface);
    max-width: 420px;
  }
  .bio-portrait img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Bio block */
  .bio-block {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: var(--space-5);
    margin-top: var(--space-3);
  }
  @media (max-width: 900px) {
    .bio-block { grid-template-columns: 1fr; }
  }
  .bio-block__lede {
    font-size: clamp(17px, 1.6vw, 22px);
    line-height: 1.55;
    margin-bottom: var(--space-2);
  }
  .bio-block__main p {
    font-size: 16px;
    line-height: 1.65;
    color: var(--text);
    opacity: 0.92;
    margin-bottom: var(--space-2);
    max-width: 60ch;
  }
  .bio-block__creds {
    background: var(--surface);
    padding: var(--space-3);
    border-left: 2px solid var(--accent);
    align-self: start;
  }
  .creds-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .creds-list li {
    padding: 10px 0;
    border-top: 1px solid var(--border);
    font-size: 14px;
    line-height: 1.5;
  }
  .creds-list li:first-child { border-top: 0; }
  .creds-list strong { color: var(--text); font-weight: 600; }

  /* Pillars */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-3);
  }
  @media (max-width: 768px) { .pillars-grid { grid-template-columns: 1fr; } }
  .pillar {
    padding: var(--space-3);
    background: var(--surface);
    border-top: 2px solid var(--accent);
  }
  .pillar h3 { font-size: 18px; margin: 0 0 var(--space-1); }
  .pillar p { font-size: 14px; line-height: 1.6; color: var(--text-muted); margin: 0; }

  /* Kit */
  .kit-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-3);
  }
  @media (max-width: 900px) { .kit-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .kit-grid { grid-template-columns: 1fr; } }
  .kit-grid > div {
    padding: var(--space-2) 0;
    border-top: 1px solid var(--border);
  }
  .kit-grid h3 {
    font-size: 13px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin: 0 0 var(--space-2);
  }
  .kit-grid ul { list-style: none; padding: 0; margin: 0; }
  .kit-grid li {
    font-size: 14px;
    line-height: 1.6;
    padding: 4px 0;
    color: var(--text);
  }

  /* Locations */
  .locations-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-3);
  }
  @media (max-width: 768px) { .locations-grid { grid-template-columns: 1fr; } }
  .locations-grid h3 {
    font-size: 13px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin: 0 0 var(--space-2);
  }
  .locations-list {
    font-size: clamp(17px, 1.6vw, 22px);
    line-height: 1.7;
    color: var(--text);
    margin: 0;
  }

  /* Testimonials on about */
  .about-testimonials {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-3);
  }
  @media (max-width: 900px) { .about-testimonials { grid-template-columns: 1fr; gap: var(--space-2); margin-top: var(--space-2); } }
  .pull-quote-card {
    margin: 0;
    padding: var(--space-3);
    background: var(--surface);
    border-left: 2px solid var(--accent);
  }
  @media (max-width: 768px) {
    .pull-quote-card { padding: var(--space-2); }
  }
  .pull-quote-card blockquote {
    font-size: 16px;
    line-height: 1.6;
    font-style: italic;
    color: var(--text);
    margin: 0 0 var(--space-2);
  }
  @media (max-width: 768px) {
    .pull-quote-card blockquote {
      font-size: 15px;
      line-height: 1.5;
      margin-bottom: var(--space-1);
    }
  }
  .pull-quote-card figcaption {
    font-size: 13px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }
  .pull-quote-card strong { color: var(--text); }

  /* FAQ */
  .faq-list {
    margin-top: var(--space-3);
    border-top: 1px solid var(--border);
    max-width: 860px;
  }
  .faq-item {
    border-bottom: 1px solid var(--border);
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: var(--space-3) 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    font-size: clamp(16px, 1.6vw, 19px);
    font-weight: 600;
    color: var(--text);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-mark {
    position: relative;
    flex-shrink: 0;
    width: 14px;
    height: 14px;
  }
  .faq-mark::before,
  .faq-mark::after {
    content: "";
    position: absolute;
    background: var(--text-muted);
    transition: transform var(--motion-normal) var(--ease-out), opacity var(--motion-normal);
  }
  .faq-mark::before { top: 6px; left: 0; width: 14px; height: 2px; }
  .faq-mark::after { top: 0; left: 6px; width: 2px; height: 14px; }
  .faq-item[open] .faq-mark::after { transform: rotate(90deg); opacity: 0; }
  .faq-item summary:hover { opacity: 0.85; }
  .faq-item p {
    margin: 0 0 var(--space-3);
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-muted);
    max-width: 70ch;
  }

  /* Final CTA */
  .final-cta-section {
    text-align: center;
    padding-top: var(--space-6);
    padding-bottom: var(--space-6);
  }
  @media (max-width: 768px) {
    .final-cta-section { padding-top: var(--space-4); padding-bottom: var(--space-4); }
  }
  @media (max-width: 480px) {
    .final-cta-section { padding-top: var(--space-3); padding-bottom: var(--space-3); }
  }
  .final-cta-section h2 {
    font-size: clamp(32px, 4.5vw, 56px);
    margin: 0 0 var(--space-3);
  }
  .final-cta-row {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    flex-wrap: wrap;
  }
  .featured-cta {

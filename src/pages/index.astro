---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import CreditGrid from '../components/CreditGrid.astro';
import AwardsGrid from '../components/AwardsGrid.astro';
import Marquee from '../components/Marquee.astro';
import { site } from '../data/site';
import { awards, credits } from '../data/awards';
import { videos } from '../data/videos';

const allWork = await getCollection('work');
const featured = allWork
  .filter((w) => w.data.featured)
  .sort((a, b) => (a.data.featuredOrder ?? 99) - (b.data.featuredOrder ?? 99))
  .slice(0, 6);

// Headline awards (the four "won" ones)
const headlineAwards = awards.filter((a) => a.status === 'won');

// Stock teasers for the showreel strip
const stockTeasers = videos.filter((v) => v.category === 'stock-teaser');

const title = 'Highly Visual — Natural-history cinematographer, Nairobi';
const description =
  "Nairobi-based drone operator and cinematographer for BBC NHU, Silverback, Plimsoll, Offspring, Nat Geo, Disney+. CAA-licensed, KFCB-registered. 14+ countries.";

// Featured-work ItemList for richer rich-result eligibility on the home page.
const featuredItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Selected work — Highly Visual',
  itemListOrder: 'ItemListOrderAscending',
  numberOfItems: featured.length,
  itemListElement: featured.map((w, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: new URL(`/work/${w.slug}/`, Astro.site).toString(),
    name: w.data.title,
  })),
};
---
<BaseLayout
  title={title}
  description={description}
  preloadImage={site.hero.rotator[0]?.src}
  extraSchema={[featuredItemList]}
  band="compact"
>
  <Hero
    title={site.hero.title}
    sub={site.hero.sub}
    cta={site.hero.cta}
    secondaryCta={{ label: 'Get in touch', href: '/contact/' }}
  />

  <!-- Section: Testimonial carousel — second screen, builds credibility immediately -->
  <TestimonialCarousel />

  <!-- Section: Featured work -->
  <section class="container featured-work reveal" aria-label="Featured work">
    <header class="section-head">
      <p class="section-title">Selected work</p>
      <h2>The work itself.</h2>
      <p class="section-lede">
        A few of the projects I've contributed drone and long-lens cinematography to in recent years —
        for the BBC Natural History Unit, Silverback Films, Plimsoll Productions, Nat Geo,
        Disney+ and Netflix. Click through to the full credit list.
      </p>
    </header>
    <div class="grid grid-3 reveal-stagger">
      {featured.map((w) => (
        <a href={`/work/${w.slug}/`} class="card">
          <div class="card-img-wrap">
            <img class="card-img" src={w.data.cardImage ?? w.data.heroImage} alt={w.data.cardAlt ?? w.data.heroAlt} loading="lazy" />
          </div>
          <div class="card-meta">
            <p class="tag">{w.data.lane.replace('-', ' ')}</p>
            <h3 class="card-title">{w.data.title}</h3>
            <p class="card-sub">{w.data.role} · {w.data.productionHouse}{w.data.distributor && <> · {w.data.distributor}</>} · {w.data.year}</p>
          </div>
        </a>
      ))}
    </div>
    <p class="featured-cta">
      <a href="/work/" class="cta cta--ghost">All work →</a>
    </p>
  </section>

  <!-- Section: Production-house marquee -->
  <Marquee label="Production houses I've worked with" />

  <!-- Section: Services strip -->
  <section class="container services-strip reveal" aria-label="Services">
    <header class="section-head">
      <p class="section-title">What I do</p>
      <h2>Four services. One operator.</h2>
      <p class="section-lede">
        Drone operations, long-lens cinematography, local film fixing across East Africa,
        and end-to-end commercial production. KFCB-registered, CAA-licensed, fully insured.
      </p>
    </header>
    <div class="grid grid-4 reveal-stagger services-grid">
      <a href="/services/#drone" class="service-card">
        <div class="service-card__img">
          <img src="/img/hero-3-canoes.jpg" alt="Aerial drone capability" loading="lazy" />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Drone &amp; aerial</h3>
          <p class="service-card__desc">CAA-licensed PfCO since 2017. DJI Inspire 3, Mavic 3 Cine. Aerial-to-aerial, low-altitude wildlife, coastal and landscape.</p>
          <span class="service-card__more">Drone services</span>
        </div>
      </a>
      <a href="/services/#long-lens" class="service-card">
        <div class="service-card__img">
          <img src="/img/hero-2-serval.jpg" alt="Long-lens wildlife cinematography" loading="lazy" />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Long-lens cinematography</h3>
          <p class="service-card__desc">Sony 200-600 and 70-200 on FX6 / FX3 / A7R5 bodies. Multi-day wildlife waits across the Mara, Tsavo, Samburu and beyond.</p>
          <span class="service-card__more">Wildlife filming</span>
        </div>
      </a>
      <a href="/fixing/" class="service-card">
        <div class="service-card__img">
          <img src="/img/sup-2-event-aerial.jpg" alt="Aerial of a major production event with marquees and crew on a Kenyan conservancy" loading="lazy" />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Local film fixing</h3>
          <p class="service-card__desc">KFCB-registered. Permits, scouting, crew, vehicles to helicopters, security, customs, accommodation. 17 services on offer.</p>
          <span class="service-card__more">Fixing services</span>
        </div>
      </a>
      <a href="/services/#production" class="service-card">
        <div class="service-card__img">
          <img src="/img/sup-2-kasas-kenya.jpg" alt="Commercial and brand production" loading="lazy" />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Commercial production</h3>
          <p class="service-card__desc">Solo end-to-end production for brand films, infomercials, documentary. Producer · director · DOP · drone · post.</p>
          <span class="service-card__more">Production work</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Section: Awards (highlighted on home; full detail on /credits/) -->
  <AwardsGrid items={headlineAwards} label="Award contributions" />

  <!-- Section: Credit grid (the wall of show artwork) -->
  <section class="container credits-section reveal" aria-label="Production credits">
    <header class="section-head">
      <p class="section-title">Production credits</p>
      <h2>30+ broadcast credits.</h2>
      <p class="section-lede">
        Drone and aerial cinematography contributions across the world's natural-history broadcast
        slate — BBC NHU, Silverback Films, Plimsoll, Nat Geo / Disney+, Netflix, Apple TV+ and beyond.
      </p>
    </header>
    <CreditGrid />
    <p class="featured-cta">
      <a href="/credits/" class="cta cta--ghost">Full credits, awards &amp; press →</a>
    </p>
  </section>

  <!-- Section: Stock + showreel teasers -->
  <section class="container reels-strip reveal" aria-label="Stock-footage teasers">
    <header class="section-head">
      <p class="section-title">Reels &amp; archive</p>
      <h2>Watch the archive.</h2>
      <p class="section-lede">
        Two short walkthroughs of the stock archive at <a href={site.sister.stock.url} target="_blank" rel="noopener noreferrer">stock.highlyvisual.com</a> — 2,700+ broadcast-quality clips and growing.
      </p>
    </header>
    <div class="grid grid-2 reveal-stagger">
      {stockTeasers.map((v) => (
        <div class="reel-card">
          <div class="reel-card__embed">
            <iframe
              src={v.embedUrl}
              title={v.title}
              loading="lazy"
              allow="autoplay; fullscreen; picture-in-picture"
              referrerpolicy="strict-origin-when-cross-origin"
              sandbox="allow-scripts allow-same-origin allow-presentation allow-popups"></iframe>
          </div>
          <div class="reel-card__meta">
            <h3>{v.title}</h3>
            <p>{v.description}</p>
            <p class="reel-card__duration">{Math.floor(v.duration / 60)}:{String(v.duration % 60).padStart(2, '0')}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Section: Press -->
  <section class="container press-section reveal" aria-label="Press">
    <header class="section-head">
      <p class="section-title">Press</p>
      <h2>Third-party coverage.</h2>
    </header>
    <ul class="press-list reveal-stagger">
      {site.press.map((p) => (
        <li>
          <a href={p.url} target="_blank" rel="noopener noreferrer">
            <span class="press-meta">{p.outlet} · {p.year}</span>
            <span class="press-title">{p.title}</span>
            <span class="press-arrow">↗</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Section: Sister sites -->
  <section class="sister-section reveal" aria-label="Sister sites">
    <div class="sister-section__grain" aria-hidden="true"></div>
    <div class="sister-section__spotlight" aria-hidden="true"></div>
    <div class="container sister-section__inner">
      <header class="section-head sister-section__head">
        <p class="section-title sister-section__eyebrow">
          <span class="eyebrow__rule" aria-hidden="true"></span>Sister sites<span class="eyebrow__rule" aria-hidden="true"></span>
        </p>
        <h2>Hire &amp; stock — separate properties.</h2>
        <p class="section-lede">
          Equipment hire and the broadcast stock archive live on dedicated domains.
          Both are run from the same Nairobi shop and share the same WhatsApp number.
        </p>
      </header>
      <div class="grid grid-2 reveal-stagger">
        <a href={site.sister.hire.url} target="_blank" rel="noopener noreferrer" class="sister-card">
          <div class="sister-card__img">
            <img src="/img/cinema-rental-inspire.jpg" alt="DJI Inspire 2 with Zenmuse gimbal — cinema-grade rental kit" loading="lazy" />
            <div class="sister-card__mask" aria-hidden="true"></div>
          </div>
          <div class="sister-card__body">
            <p class="eyebrow">{site.sister.hire.tag}</p>
            <h3>hirevisual.com</h3>
            <p>{site.sister.hire.desc}</p>
            <span class="sister-card__more">Visit hirevisual.com <span class="sister-card__arrow" aria-hidden="true">→</span></span>
          </div>
        </a>
        <a href={site.sister.stock.url} target="_blank" rel="noopener noreferrer" class="sister-card">
          <div class="sister-card__img">
            <img src="/img/bts-elephants-sunset.jpg" alt="Aerial wildlife footage from the stock archive" loading="lazy" />
            <div class="sister-card__mask" aria-hidden="true"></div>
          </div>
          <div class="sister-card__body">
            <p class="eyebrow">{site.sister.stock.tag}</p>
            <h3>stock.highlyvisual.com</h3>
            <p>{site.sister.stock.desc}</p>
            <span class="sister-card__more">Visit stock.highlyvisual.com <span class="sister-card__arrow" aria-hidden="true">→</span></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Section: Final CTA -->
  <section class="container final-cta reveal" aria-label="Get in touch">
    <h2>Working in East Africa?</h2>
    <p class="section-lede">
      Word-of-mouth referrals are how most projects find me. If you've been pointed this way,
      mentioning who sent you helps me reply faster.
    </p>
    <div class="final-cta-row">
      <a href="/contact/" class="cta">Start a conversation</a>
      <a href="/work/" class="cta cta--ghost">See all work</a>
      <a href="/fixing/" class="cta cta--ghost">Fixing services</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section-head {
    margin-bottom: var(--space-4);
    max-width: 900px;
  }
  @media (max-width: 768px) {
    .section-head { margin-bottom: var(--space-3); }
  }
  .section-head h2 {
    margin: var(--space-1) 0 var(--space-2);
  }
  .featured-cta {
    margin-top: var(--space-4);
    text-align: right;
  }
  @media (max-width: 768px) {
    .featured-cta { text-align: left; }
  }

  .services-grid {
    margin-bottom: var(--space-4);
  }

  .credits-section {
    padding-top: var(--space-5);
  }
  @media (max-width: 768px) {
    .credits-section { padding-top: var(--space-3); }
  }

  /* Reel cards */
  .reel-card {
    background: var(--surface);
    overflow: hidden;
  }
  .reel-card__embed {
    position: relative;
    padding-top: 56.25%;
    background: var(--bg);
  }
  .reel-card__embed iframe {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    border: 0;
  }
  .reel-card__meta {
    padding: var(--space-3);
  }
  .reel-card__meta h3 {
    font-size: 19px;
    margin: 0 0 var(--space-1);
  }
  .reel-card__meta p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0 0 var(--space-1);
  }
  .reel-card__duration {
    font-size: 12px;
    color: var(--text-faint);
    letter-spacing: 0.08em;
    margin: 0;
  }

  /* Press */
  .press-list { list-style: none; padding: 0; margin: 0; }
  .press-list li a {
    display: grid;
    grid-template-columns: 280px 1fr 32px;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--border);
    font-size: 16px;
    transition: padding-left var(--motion-normal) var(--ease-out);
  }
  .press-list li:last-child a { border-bottom: 1px solid var(--border); }
  .press-list li a:hover { padding-left: 12px; opacity: 1; }
  .press-meta { color: var(--text-muted); font-size: 13px; letter-spacing: 0.04em; }
  .press-title { color: var(--text); }
  .press-arrow { color: var(--text-muted); font-size: 18px; text-align: right; }
  @media (max-width: 768px) {
    .press-list li a { grid-template-columns: 1fr; gap: 4px; }
    .press-arrow { display: none; }
  }

  /* === Sister sites section — full-bleed depth treatment === */
  .sister-section {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background:
      linear-gradient(to bottom, rgba(245,244,241,0.02) 0%, transparent 30%, rgba(0,0,0,0.30) 100%),
      var(--bg);
  }
  .sister-section__inner {
    position: relative;
    z-index: 2;
  }
  /* Spotlight — warm-white luminance only */
  .sister-section__spotlight {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(60% 50% at 50% 0%, rgba(245,244,241,0.08) 0%, rgba(245,244,241,0.02) 40%, transparent 70%);
  }
  /* Film grain — same SVG noise as SiteBand for cross-page coherence */
  .sister-section__grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.15;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='280' height='280' viewBox='0 0 280 280'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='1.6' numOctaves='2' stitchTiles='stitch' seed='5'/><feColorMatrix values='0 0 0 0 0.96  0 0 0 0 0.95  0 0 0 0 0.91  0 0 0 0.85 0'/></filter><rect width='280' height='280' filter='url(%23n)'/></svg>");
    background-size: 280px 280px;
  }
  .sister-section__head { text-align: center; margin-left: auto; margin-right: auto; }
  .sister-section__head .section-lede { margin-left: auto; margin-right: auto; }
  .sister-section__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    letter-spacing: 0.22em;
  }
  .sister-section__eyebrow .eyebrow__rule {
    display: inline-block;
    width: 36px;
    height: 1px;
    background: var(--border-strong);
  }

  /* Sister site cards — image-led, dimensional */
  .sister-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    overflow: hidden;
    text-decoration: none;
    color: var(--text);
    transition: background var(--motion-normal), border-color var(--motion-normal), transform var(--motion-normal), box-shadow var(--motion-normal);
    box-shadow:
      inset 0 1px 0 rgba(245,244,241,0.04),
      0 1px 0 rgba(0,0,0,0.4);
  }
  .sister-card:hover {
    background: var(--surface-2);
    border-color: var(--border-strong);
    transform: translateY(-4px);
    opacity: 1;
    box-shadow:
      inset 0 1px 0 rgba(245,244,241,0.06),
      0 16px 40px rgba(0,0,0,0.55);
  }
  .sister-card__img {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .sister-card__img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 1400ms var(--ease-out-soft), filter var(--motion-normal);
    filter: grayscale(0.25) contrast(0.98) brightness(0.85);
  }
  .sister-card:hover .sister-card__img img {
    transform: scale(1.05);
    filter: grayscale(0) contrast(1) brightness(1);
  }
  /* Bottom-fade mask to bleed image into card surface */
  .sister-card__mask {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to bottom, rgba(10,10,11,0) 60%, var(--surface) 100%);
    transition: background var(--motion-normal);
  }
  .sister-card:hover .sister-card__mask {
    background: linear-gradient(to bottom, rgba(10,10,11,0) 60%, var(--surface-2) 100%);
  }
  .sister-card__body {
    padding: var(--space-3);
  }
  .sister-card .eyebrow {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0 0 var(--space-1);
  }
  .sister-card h3 {
    font-size: clamp(24px, 2.4vw, 32px);
    margin: 0 0 var(--space-1);
    letter-spacing: -0.022em;
    line-height: 1.05;
  }
  .sister-card p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0 0 var(--space-2);
  }
  .sister-card__more {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.04em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .sister-card__arrow {
    display: inline-block;
    transition: transform var(--motion-normal) var(--ease-out);
  }
  .sister-card:hover .sister-card__arrow {
    transform: translateX(6px);
  }

  /* Final CTA */
  .final-cta {
    text-align: center;
    padding-top: var(--space-6);
    padding-bottom: var(--space-6);
  }
  @media (max-width: 768px) {
    .final-cta { padding-top: var(--space-4); padding-bottom: var(--space-4); }
  }
  @media (max-width: 480px) {
    .final-cta { padding-top: var(--space-3); padding-bottom: var(--space-3); }
  }
  .final-cta h2 {
    font-size: clamp(36px, 5vw, 64px);
    margin: 0 0 var(--space-2);
  }
  .final-cta .section-lede {
    margin-left: auto;
    margin-right: auto;
    margin-bottom: var(--space-3);
  }
  .final-cta-row {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

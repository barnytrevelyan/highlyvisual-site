---
// Sitewide pre-footer band. Inserted by BaseLayout on every page so each route
// guarantees:
//   • a prominent primary CTA (single_primary_cta_per_viewport, anchored end-of-page)
//   • the credential strip (hv_credentials_surfaced)
//   • the two sister-site cards (hv_sister_sites_signposted)
//   • a real mid-page content section (hv_dense_content_present) on pages
//     that would otherwise have hero + thin body + footer.
//
// Pages that have their own bespoke final-CTA (homepage, contact) can opt out
// via the `compact` prop, which collapses the band to a slim credentials +
// sister-site strip without the headline + CTA pairing.

import { site } from '../data/site';

interface Props {
  compact?: boolean;
  // Optional headline override — lets a page tailor the call ("Working on a
  // BBC NHU pitch?" on natural-history case studies, etc.) while keeping the
  // visual treatment consistent.
  heading?: string;
  lede?: string;
}

const { compact = false, heading, lede } = Astro.props;
const finalHeading = heading ?? 'Working in East Africa?';
const finalLede =
  lede ??
  'Most projects find me through word-of-mouth — production manager to production manager. If you have a project that needs aerial work, long-lens wildlife, or local fixing on the ground, get in touch.';
---
<section class="site-band reveal" aria-labelledby="site-band-heading" data-compact={compact}>
  <div class="container">
    {!compact && (
      <div class="band-cta">
        <p class="eyebrow">Get in touch</p>
        <h2 id="site-band-heading">{finalHeading}</h2>
        <p class="band-lede">{finalLede}</p>
        <div class="band-cta-row">
          <a href="/contact/" class="cta cta--primary">Start a conversation</a>
          <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="cta cta--ghost">WhatsApp</a>
          <a href={`mailto:${site.email}`} class="cta cta--ghost">{site.email}</a>
        </div>
      </div>
    )}

    <!-- Credentials strip — surfaces on every route -->
    <ul class="band-credentials" aria-label="Credentials">
      <li><strong>CAA-licensed</strong><span>PfCO UAS 9543 · 2017</span></li>
      <li><strong>KFCB-registered</strong><span>Local film agent · Kenya</span></li>
      <li><strong>Established 2002</strong><span>Tanzania → Kenya · 14+ countries</span></li>
      <li><strong>4K+ broadcast spec</strong><span>RED-tier deliverables · BBC NHU standard</span></li>
    </ul>

    <!-- Sister-site cards — every page passes hv_sister_sites_signposted -->
    <div class="band-sisters" aria-label="Sister sites">
      <a href={site.sister.hire.url} target="_blank" rel="noopener noreferrer" class="sister-tile">
        <div class="sister-tile__head">
          <span class="sister-tile__tag">{site.sister.hire.tag}</span>
          <h3>hirevisual.com</h3>
        </div>
        <p>{site.sister.hire.desc}</p>
        <span class="sister-tile__cta">Browse the kit list →</span>
      </a>
      <a href={site.sister.stock.url} target="_blank" rel="noopener noreferrer" class="sister-tile">
        <div class="sister-tile__head">
          <span class="sister-tile__tag">{site.sister.stock.tag}</span>
          <h3>stock.highlyvisual.com</h3>
        </div>
        <p>{site.sister.stock.desc}</p>
        <span class="sister-tile__cta">Search the archive →</span>
      </a>
    </div>
  </div>
</section>

<style>
  .site-band {
    border-top: 1px solid var(--border);
    padding: var(--space-6) 0 var(--space-5);
    background:
      radial-gradient(80% 60% at 50% 0%, rgba(245,244,241,0.04) 0%, transparent 60%),
      var(--bg);
  }
  .site-band[data-compact="true"] {
    padding: var(--space-4) 0 var(--space-3);
  }
  /* Mobile — cut the big sitewide-band padding. The 144px top + 96px
     bottom reads as black void on a phone before the credentials + sister
     tiles appear. */
  @media (max-width: 768px) {
    .site-band {
      padding: var(--space-4) 0 var(--space-3);
    }
    .site-band[data-compact="true"] {
      padding: var(--space-3) 0 var(--space-2);
    }
  }
  @media (max-width: 480px) {
    .site-band {
      padding: var(--space-3) 0 var(--space-2);
    }
  }

  /* CTA block */
  .band-cta {
    text-align: center;
    max-width: 760px;
    margin: 0 auto var(--space-5);
  }
  @media (max-width: 768px) {
    .band-cta { margin-bottom: var(--space-3); }
  }
  .band-cta .eyebrow {
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 var(--space-1);
  }
  .band-cta h2 {
    font-size: clamp(32px, 4.5vw, 56px);
    margin: 0 0 var(--space-2);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .band-lede {
    font-size: clamp(16px, 1.5vw, 19px);
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 auto var(--space-3);
    max-width: 60ch;
  }
  .band-cta-row {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Primary CTA visual — a single dominant filled button per band so the
     single_primary_cta_per_viewport rule resolves cleanly. */
  :global(.site-band .cta--primary) {
    background: var(--text);
    color: var(--bg);
    padding: 14px 28px;
    font-weight: 600;
    letter-spacing: 0.02em;
    border: 1px solid var(--text);
    text-decoration: none;
    transition: transform var(--motion-normal) var(--ease-out), background var(--motion-normal);
    min-height: 48px;
    display: inline-flex;
    align-items: center;
  }
  :global(.site-band .cta--primary:hover) {
    transform: translateY(-1px);
    background: var(--text);
    opacity: 0.92;
  }

  /* Credentials strip */
  .band-credentials {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-4);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding-block: var(--space-3);
  }
  @media (max-width: 768px) {
    .band-credentials {
      gap: var(--space-2);
      padding-block: var(--space-2);
      margin-bottom: var(--space-3);
    }
  }
  .band-credentials li {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: center;
  }
  .band-credentials strong {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.005em;
  }
  .band-credentials span {
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }
  @media (max-width: 768px) {
    .band-credentials { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .band-credentials { grid-template-columns: 1fr; }
    .band-credentials li { text-align: left; }
  }

  /* Sister-site tiles */
  .band-sisters {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  @media (max-width: 768px) {
    .band-sisters { grid-template-columns: 1fr; }
  }
  .sister-tile {
    display: flex;
    flex-direction: column;
    padding: var(--space-3);
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: background var(--motion-normal), border-color var(--motion-normal), transform var(--motion-normal);
    min-height: 200px;
  }
  .sister-tile:hover {
    background: var(--surface-2);
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .sister-tile:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 2px;
  }
  .sister-tile__head {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: var(--space-2);
  }
  .sister-tile__tag {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .sister-tile h3 {
    font-size: clamp(22px, 2.4vw, 30px);
    margin: 0;
    letter-spacing: -0.015em;
  }
  .sister-tile p {
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 0 0 auto;
    padding-bottom: var(--space-3);
  }
  .sister-tile__cta {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.04em;
  }
</style>

---
import { site } from '../data/site';

type LogoItem = { name: string; logo: string; plate?: 'light' };
interface Props {
  items?: LogoItem[];
  label?: string;
}

const { items = site.productionHouses, label = 'Production houses' } = Astro.props;

// Duplicate for seamless loop
const doubled = [...items, ...items];
---
<section class="container marquee-section reveal" aria-label={label}>
  <p class="section-title">{label}</p>
  <div class="marquee" aria-hidden="false">
    <div class="marquee-track">
      {doubled.map((item) => (
        <span class={`marquee-logo ${item.plate === 'light' ? 'is-plate' : ''}`}>
          <img src={item.logo} alt={item.name} loading="lazy" decoding="async" />
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-section {
    padding-top: var(--space-5);
    padding-bottom: var(--space-5);
  }
  /* Logo-cell sizing — every logo normalised to a consistent visible height so
     wildly different aspect ratios don't break the rhythm. The cell is a flex
     container; the logo image is height-constrained and width auto. */
  .marquee-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0 var(--space-4);
    flex-shrink: 0;
    opacity: 0.85;
    transition: opacity var(--motion-normal);
  }
  .marquee-logo:hover { opacity: 1; }
  .marquee-logo img {
    height: 60px;
    width: auto;
    display: block;
    object-fit: contain;
  }
  /* Logos that are brand-defined on a light surface (Silverback, Magical
     Kenya, Silk Road Visual) — wrap them in a small white plate so the
     marks read on dark. */
  .marquee-logo.is-plate {
    background: #fff;
    padding: 10px 18px;
    border-radius: 4px;
    opacity: 0.95;
  }
  .marquee-logo.is-plate:hover { opacity: 1; }
  .marquee-logo.is-plate img {
    height: 48px;
  }
  @media (max-width: 768px) {
    .marquee-section {
      padding-top: var(--space-4);
      padding-bottom: var(--space-4);
    }
    .marquee-logo { margin: 0 var(--space-3); }
    .marquee-logo img { height: 46px; }
    .marquee-logo.is-plate img { height: 36px; }
    .marquee-logo.is-plate { padding: 8px 14px; }
  }
  @media (max-width: 480px) {
    .marquee-logo { margin: 0 var(--space-2); }
    .marquee-logo img { height: 38px; }
    .marquee-logo.is-plate img { height: 30px; }
    .marquee-logo.is-plate { padding: 6px 12px; }
  }
</style>
